# ── Telegram Bot ──────────────────────────────────────────
# Получить у @BotFather командой /newbot
BOT_TOKEN=

# Username бота БЕЗ @, например: MyBot_bot
# Автоматически заполняется при первом запуске через /admin1234
BOT_USERNAME=

# Telegram user ID администраторов (через запятую). Узнать у @userinfobot
ADMIN_IDS=

# Код для входа в меню администратора через бота (/admin<КОД>)
ADMIN_SETUP_CODE=1234

# ── База данных ───────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./apex_lead_router.db
LOG_LEVEL=INFO

# ── Web-сервер ────────────────────────────────────────────
# PUBLIC_BASE_URL — публичный URL на который смотрит Google Sheet скрипт.
# Если используете ngrok: вставьте URL из `ngrok http 8000` (напр. https://xxxx.ngrok-free.app)
# Если у сервера есть IP/домен: http://YOUR_IP:8000 или https://yourdomain.com
PUBLIC_BASE_URL=https://CHANGE_ME.ngrok-free.app
WEB_HOST=0.0.0.0
WEB_PORT=8000

# ── Facebook (опционально, можно оставить пустым) ─────────
FACEBOOK_VERIFY_TOKEN=apex_verify_changeme
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_GRAPH_VERSION=v19.0

# ── Google Sheets (опционально) ───────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=
